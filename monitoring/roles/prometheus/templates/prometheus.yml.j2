global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node_exporter_monitoring'
    static_configs:
      - targets: ['localhost:9100']
        labels:
          instance: 'monitoring-server'

  - job_name: 'node_exporter_target'
    static_configs:
      - targets: ['{{ target_server_ip }}:9100']
        labels:
          instance: 'target-server'
